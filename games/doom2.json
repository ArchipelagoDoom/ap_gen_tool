        "MAP12":{
            // We need to turn the balcony you jump down from into the building, into a lift
            "linedefs":{
                "271":{"special": 62, "tag": 42, "flags": 12}
            },
            "sectors":{
                "132":{"tag": 42, "floor_pic": "STEP1"}
            },
            "sidedefs":{
                "316":{"lower": "SUPPORT2"},
                "318":{"lower": "SUPPORT2"},
                "366":{"lower": "SUPPORT2"}
            }
        },
        "MAP24":{
            "things":{
                // As the ending room is an inescapable death pit, make the enemies flying only.
                "247":{"flying_enemies_only": true},
                "248":{"flying_enemies_only": true},
                "249":{"flying_enemies_only": true},
                "255":{"flying_enemies_only": true},
                "256":{"flying_enemies_only": true},
