                "258":{"flying_enemies_only": true},
                "259":{"flying_enemies_only": true},
                "260":{"flying_enemies_only": true}
            }
        },
        "MAP27":{
            "linedefs":{
                // Make the platform lowering switch retriggerable
                "727":{"special": 70},

                // Allow opening up the Pain Elemental cubby from inside
                "580":{"special": 31},
                "581":{"special": 31}
            }
        },
        "MAP28":{
            // Allow opening a wall that traps you in from behind
            "linedefs":{
                "554":{"special": 61, "tag": 7}
            }
        }
    },

